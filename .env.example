# Copy to .env.local and adjust. Vite only exposes vars prefixed with VITE_.

# API root (must include /api/v1). Defaults to production Railway if unset.
# VITE_API_BASE_URL=https://your-backend.example.com/api/v1

# Token refresh: path appended to VITE_API_BASE_URL, or a full https URL.
# VITE_AUTH_REFRESH_PATH=/auth/refresh

# If your API expects { "refresh_token": "..." } instead of refreshToken:
# VITE_AUTH_REFRESH_TOKEN_FIELD=refresh_token

# Web Push (works in mobile WebView when set). Prefer this on Android without Firebase.
# VITE_VAPID_PUBLIC_KEY=

# Android native FCM — only set to "true" after adding android/app/google-services.json from Firebase.
# Without Firebase, native Capacitor push can crash on Enable notifications.
# VITE_ANDROID_USE_NATIVE_FCM=true

# AI assistant: backend route that proxies to Gemini (never put API keys in the app).
# POST JSON { "message": string, "context": string } with Authorization: Bearer <access token>
# Response JSON { "reply": string } or { "message": string } or plain text.
# VITE_AI_CHAT_URL=https://your-backend.example.com/api/v1/ai/chat
